<%- include('partials/header') %>

<!-- ─── Hero Section ──────────────────────────────────────────────────────────── -->
<section class="hero-section d-flex align-items-center" id="home">
  <div class="hero-bg-orb orb-1"></div>
  <div class="hero-bg-orb orb-2"></div>
  <div class="container position-relative">
    <div class="row align-items-center min-vh-100">
      <div class="col-lg-6 py-5">
        <span class="badge-pill mb-4">
          <i class="bi bi-stars me-1"></i> Cognifyz Internship · Task 01
        </span>
        <h1 class="hero-title mb-4">
          Your Data.<br />
          <span class="text-gradient">Secured.</span><br />
          Organized.
        </h1>
        <p class="hero-subtitle mb-5">
          DataVault is a full-stack user management platform built with
          <strong>Node.js</strong>, <strong>Express</strong>, and <strong>EJS</strong> —
          progressively enhanced across 8 Cognifyz internship tasks.
        </p>
        <div class="d-flex flex-wrap gap-3">
          <a href="#features" class="btn btn-accent btn-lg px-5">
            <i class="bi bi-rocket-takeoff me-2"></i>Explore Features
          </a>
          <a href="#contact" class="btn btn-ghost btn-lg px-5">
            <i class="bi bi-envelope me-2"></i>Get in Touch
          </a>
        </div>
        <!-- Tech Stack Pills -->
        <div class="tech-pills mt-5">
          <span class="tech-pill"><i class="bi bi-filetype-js me-1"></i>Node.js</span>
          <span class="tech-pill"><i class="bi bi-server me-1"></i>Express</span>
          <span class="tech-pill"><i class="bi bi-file-earmark-code me-1"></i>EJS</span>
          <span class="tech-pill"><i class="bi bi-bootstrap me-1"></i>Bootstrap 5</span>
        </div>
      </div>
      <div class="col-lg-6 d-none d-lg-flex justify-content-center">
        <div class="hero-card glass-card">
          <div class="hero-card-header">
            <div class="dot red"></div>
            <div class="dot yellow"></div>
            <div class="dot green"></div>
            <span class="ms-2 text-muted small">server.js</span>
          </div>
          <pre class="code-block"><code><span class="code-keyword">const</span> express = <span class="code-fn">require</span>(<span class="code-str">'express'</span>);
<span class="code-keyword">const</span> app = <span class="code-fn">express</span>();

app.<span class="code-fn">set</span>(<span class="code-str">'view engine'</span>, <span class="code-str">'ejs'</span>);

app.<span class="code-fn">get</span>(<span class="code-str">'/'</span>, (req, res) => {
  res.<span class="code-fn">render</span>(<span class="code-str">'index'</span>, {
    title: <span class="code-str">'DataVault'</span>
  });
});

app.<span class="code-fn">listen</span>(<span class="code-num">3000</span>, () => {
  console.<span class="code-fn">log</span>(<span class="code-str">'🚀 Server running!'</span>);
});</code></pre>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Stats Bar ─────────────────────────────────────────────────────────────── -->
