</section>

<!-- ─── Contact Section ───────────────────────────────────────────────────────── -->
<section class="contact-section py-6" id="contact">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <div class="text-center mb-5">
          <span class="badge-pill mb-3"><i class="bi bi-envelope me-1"></i>Get In Touch</span>
          <h2 class="section-title">Contact Us</h2>
          <p class="section-subtitle">Fill in the form and we'll get back to you.</p>
        </div>

        <!-- Flash Message (server-rendered) -->
        <% if (message) { %>
          <div class="alert-custom alert-<%= messageType %> mb-4" role="alert" id="flashMsg">
            <i class="bi bi-<%= messageType === 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill' %> me-2"></i>
            <%= message %>
          </div>
        <% } %>

        <!-- Contact Form -->
        <form action="/contact" method="POST" class="glass-form" id="contactForm" novalidate>
          <div class="row g-4">
            <div class="col-md-6">
              <div class="form-floating-custom">
                <label for="name">Full Name <span class="text-accent">*</span></label>
                <input type="text" id="name" name="name" class="form-input" placeholder="John Doe" required />
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-floating-custom">
                <label for="email">Email Address <span class="text-accent">*</span></label>
                <input type="email" id="email" name="email" class="form-input" placeholder="john@example.com" required />
              </div>
            </div>
            <div class="col-12">
              <div class="form-floating-custom">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" class="form-input" placeholder="What's this about?" />
              </div>
            </div>
            <div class="col-12">
              <div class="form-floating-custom">
                <label for="message">Message <span class="text-accent">*</span></label>
                <textarea id="message" name="message" class="form-input form-textarea" placeholder="Write your message here..." rows="5" required></textarea>
              </div>
            </div>
            <div class="col-12 text-center">
              <button type="submit" class="btn btn-accent btn-lg px-6" id="submitBtn">
                <i class="bi bi-send me-2"></i>Send Message
              </button>
            </div>
          </div>
        </form>

      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
