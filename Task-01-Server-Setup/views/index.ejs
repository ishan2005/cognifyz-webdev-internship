<!-- ─── CONTACT ───────────────────────────────────────────────────────────── -->
<section class="gh-contact-section" id="contact">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">

        <div class="mb-4">
          <div class="gh-section-label">Get in Touch</div>
          <h2 class="gh-section-title">Open an Issue 📬</h2>
          <p class="gh-section-desc">Have a question or collaboration idea? Send a message below.</p>
        </div>

        <!-- Flash Alert -->
        <% if (message) { %>
          <div class="gh-alert <%= messageType %>">
            <i class="bi bi-<%= messageType === 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill' %>" style="font-size:18px;flex-shrink:0;margin-top:1px"></i>
            <div class="gh-alert-body">
              <strong><%= messageType === 'success' ? 'Message sent!' : 'Something went wrong' %></strong>
              <%= message %>
            </div>
          </div>
        <% } %>

        <!-- Form wrapped in GitHub PR / Issue style box -->
        <div class="gh-form-wrapper">
          <div class="gh-form-header">
            <i class="bi bi-chat-dots-fill" style="color:var(--gh-green)"></i>
            New Message &nbsp;<span style="color:var(--gh-text-3);font-weight:400;font-size:12px">· Required fields marked <span style="color:var(--gh-red)">*</span></span>
          </div>
          <div class="gh-form-body">
            <form action="/contact" method="POST" id="contactForm" novalidate>

              <div class="gh-form-row">
                <div class="gh-form-group">
                  <label class="gh-label" for="name">Full Name <span class="gh-required">*</span></label>
                  <input type="text" id="name" name="name" class="gh-input" placeholder="John Doe" required />
                </div>
                <div class="gh-form-group">
                  <label class="gh-label" for="email">Email <span class="gh-required">*</span></label>
                  <input type="email" id="email" name="email" class="gh-input" placeholder="john@example.com" required />
                </div>
              </div>

              <div class="gh-form-group">
                <label class="gh-label" for="subject">Subject <span style="color:var(--gh-text-3);font-weight:400">(optional)</span></label>
                <input type="text" id="subject" name="subject" class="gh-input" placeholder="What's this about?" />
              </div>

              <div class="gh-form-group">
                <label class="gh-label" for="message">Message <span class="gh-required">*</span></label>
                <textarea id="message" name="message" class="gh-input" rows="5" placeholder="Leave a comment..." required></textarea>
                <p class="gh-form-note">Styling supported. Be excellent to each other.</p>
              </div>

              <div style="display:flex;justify-content:flex-end;gap:8px;padding-top:8px;border-top:1px solid var(--gh-border);margin-top:8px">
                <button type="reset" class="gh-btn gh-btn-default">
                  <i class="bi bi-x-lg"></i> Clear
                </button>
                <button type="submit" class="gh-btn gh-btn-primary" id="submitBtn">
                  <i class="bi bi-send-fill"></i> Submit
                </button>
              </div>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

