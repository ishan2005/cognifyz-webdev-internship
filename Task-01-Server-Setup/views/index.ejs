<!-- Contribution Graph Generator -->
<script>
  (function() {
    const grid = document.getElementById('contribGrid');
    if (!grid) return;
    const levels = [null, 'l1', 'l2', 'l3', 'l4'];
    const cols = 52;
    for (let c = 0; c < cols; c++) {
      const col = document.createElement('div');
      col.className = 'gh-contrib-col';
      for (let r = 0; r < 7; r++) {
        const cell = document.createElement('div');
        const rand = Math.random();
        // Weight toward empty for most, active for recent weeks
        const recentBoost = c > 48 ? 0.4 : 0;
        let lvl = null;
        if (rand < 0.35 + recentBoost) {
          const l = Math.ceil(Math.random() * 4);
          lvl = levels[l];
        }
        cell.className = 'gh-contrib-cell' + (lvl ? ' ' + lvl : '');
        col.appendChild(cell);
      }
      grid.appendChild(col);
    }
  })();
</script>
