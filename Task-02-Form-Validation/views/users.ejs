<%- include('partials/header') %>

<main class="gh-main">
  <div class="container">

    <!-- Page Header -->
    <div class="gh-page-header">
      <div class="gh-section-label">Task 02 — In-Memory Store</div>
      <h1 class="gh-page-title">Registered Users</h1>
      <p class="gh-page-desc">
        All users stored in a server-side <code>Map</code> object. Data resets when the server restarts —
        persistent storage is added in Task 06 with MongoDB.
      </p>
    </div>

    <!-- Action Bar -->
    <div class="gh-action-bar">
      <span class="gh-user-count">
        <i class="bi bi-people-fill" style="color:var(--gh-blue)"></i>
        <%= users.length %> user<%= users.length !== 1 ? 's' : '' %> registered
      </span>
      <a href="/register" class="gh-btn gh-btn-primary">
        <i class="bi bi-person-plus-fill"></i> New Registration
      </a>
    </div>

    <% if (users.length === 0) { %>
      <!-- Empty State -->
      <div class="gh-empty-state">
        <i class="bi bi-inbox gh-empty-icon"></i>
        <h3>No users yet</h3>
        <p>Register the first user to see them appear here.</p>
        <a href="/register" class="gh-btn gh-btn-primary mt-3">
          <i class="bi bi-person-plus-fill"></i> Register Now
        </a>
      </div>
    <% } else { %>
      <!-- Users Table -->
      <div class="gh-table-wrapper">
        <table class="gh-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Date of Birth</th>
              <th>Registered At</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((user, i) => { %>
            <tr>
              <td class="gh-td-muted"><%= users.length - i %></td>
              <td>
                <div class="gh-user-cell">
                  <div class="gh-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                  <span class="gh-user-name"><%= user.name %></span>
                </div>
              </td>
              <td><a href="mailto:<%= user.email %>" class="gh-link"><%= user.email %></a></td>
              <td class="gh-td-mono"><%= user.phone %></td>
              <td class="gh-td-mono"><%= user.dob %></td>
              <td class="gh-td-muted gh-td-mono"><%= new Date(user.createdAt).toLocaleString('en-IN') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Store Info -->
      <div class="gh-info-banner mt-4" style="background:rgba(9,105,218,0.04);">
        <i class="bi bi-database" style="color:var(--gh-blue)"></i>
        <div>
          <strong>In-Memory Map Store</strong> — Data lives in <code>server.js → usersMap</code>.
          This is a <code>Map&lt;email, userObject&gt;</code>. Restart server = data cleared.
          Task 06 replaces this with MongoDB Atlas.
        </div>
      </div>
    <% } %>

  </div>
</main>

<%- include('partials/footer') %>
